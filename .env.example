# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Admin auth
ADMIN_JWT_SECRET="put-a-long-random-secret-at-least-32-chars-here"
ADMIN_2FA_CODE="246810"
ADMIN_2FA_TTL_SECONDS="300"
ADMIN_LOGIN_CHALLENGE_TTL_SECONDS="300"
ADMIN_MOBILE_SESSION_TTL_SECONDS="28800"

# Public URLs
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"

# Public data freshness for customer-facing pages/API cache.
# Lower = faster website updates after admin changes; 10 is stable for Vercel/Neon.
PUBLIC_DATA_REVALIDATE_SECONDS="10"

# KHPay real payment config
KHPAY_BASE_URL="https://khpay.site/api/v1"
KHPAY_API_KEY=""
KHPAY_WEBHOOK_SECRET=""

# Local testing only. Never set true in production.
PAYMENT_SIMULATION_MODE="false"

# Optional local-dev fallback polling from public order GET.
# Never needed in production because production must be webhook/admin/internal only.
ALLOW_PUBLIC_PAYMENT_SYNC="false"

# CamRapidSecure old working top-up API
CAMRAPID_BASE_URL="https://partner.camrapidsecure.com/api"
CAMRAPID_API_KEY=""

# Internal request logging + daily Telegram report
# Use long random values. Example: openssl rand -hex 32
INTERNAL_SECURITY_SECRET=""
CRON_SECRET=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Cloudflare Analytics API for dashboard bot/DDoS protected counters
# Token permissions: Account > Account Analytics > Read, Zone > Zone > Read.
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# Telegram alert when Cloudflare protected/security events cross levels in one Cambodia day.
# Default levels: 1K,10K,20K,50K,100K,200K,500K,1M,2M,5M,10M,20M
# Metric options: protected, blocked, bot, ddos, security
CLOUDFLARE_ALERT_THRESHOLDS="1K,10K,20K,50K,100K,200K,500K,1M,2M,5M,10M,20M"
CLOUDFLARE_ALERT_METRIC="protected"
