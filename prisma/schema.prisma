// Prisma schema for  JASMINTOPUP
// Database: PostgreSQL / Neon / Vercel
// After edit run:
// npx prisma format
// npx prisma db push
// npx prisma generate

generator client {
  provider = "prisma-client-js"

  // Vercel lambdas run on Amazon Linux 2023 (openssl 3.0).
  // Without this the generated engine binary may fail in production.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  publisher      String
  description    String?
  imageUrl       String
  bannerUrl      String?
  currencyName   String
  uidLabel       String    @default("Player ID")
  uidExample     String?
  requiresServer Boolean   @default(false)
  servers        String    @default("[]")
  featured       Boolean   @default(false)
  active         Boolean   @default(true)
  sortOrder      Int       @default(0)
  seoTitle       String?
  seoDescription String?
  products       Product[]
  orders         Order[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Product {
  id           String   @id @default(cuid())
  gameId       String
  game         Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name         String
  amount       Int
  bonus        Int      @default(0)
  priceUsd     Float
  priceKhr     Float?
  badge        String?
  imageUrl     String?
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  supplierCode String?
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([gameId, active])
}

model Order {
  id               String     @id @default(cuid())
  orderNumber      String     @unique
  gameId           String
  game             Game       @relation(fields: [gameId], references: [id])
  productId        String
  product          Product    @relation(fields: [productId], references: [id])
  playerUid        String
  serverId         String?
  playerNickname   String?
  customerEmail    String?
  customerPhone    String?
  amountUsd        Float
  amountKhr        Float?
  currency         String     @default("USD")
  paymentMethod    String
  paymentRef       String?    @unique
  paymentUrl       String?
  qrString         String?
  paymentExpiresAt DateTime?
  status           String     @default("PENDING")
  deliveryNote     String?
  failureReason    String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  paidAt           DateTime?
  deliveredAt      DateTime?
  promoCodeId      String?
  promoCode        PromoCode? @relation(fields: [promoCodeId], references: [id])
  discountUsd      Float      @default(0)

  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String
  discountValue Float
  minOrderUsd   Float     @default(0)
  maxUses       Int       @default(0)
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
}

model Admin {
  id              String                @id @default(cuid())
  email           String                @unique
  passwordHash    String
  name            String?
  role            String                @default("ADMIN")
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  lastLoginAt     DateTime?
  totpSecret      String?
  mobileSessions  AdminSession[]
  loginChallenges AdminLoginChallenge[]
}

model Settings {
  id               Int      @id @default(1)
  telegramBotToken String?
  telegramChatId   String?
  updatedAt        DateTime @updatedAt

  siteName     String @default("JASMIN TOPUP")
  exchangeRate Float  @default(4100)

  supportTelegram String?
  supportTikTok   String?
  supportEmail    String?

  maintenanceMode    Boolean @default(false)
  maintenanceMessage String?

  announcementEnabled Boolean @default(false)
  announcement        String?
  announcementTone    String?

  appMinSupportedVersion String  @default("1.0.0")
  appLatestVersion       String  @default("1.0.0")
  appForceUpdate         Boolean @default(false)
  appUpdateUrl           String?

  ordersEnabled   Boolean @default(true)
  paymentsEnabled Boolean @default(true)
  promosEnabled   Boolean @default(true)

  logoUrl     String?
  logoText    String?
  logoTagline String?
}

model HeroBanner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  ctaLabel  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String
  coverUrl    String?
  tag         String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  adminEmail String?
  action     String
  targetType String?
  targetId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model BlockedIdentity {
  id        String   @id @default(cuid())
  type      String
  value     String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([type, value])
  @@index([type])
  @@index([value])
  @@index([createdAt])
}

model AdminAuthLock {
  id          String    @id @default(cuid())
  identifier  String    @unique
  failCount   Int       @default(0)
  lockedUntil DateTime?
  forever     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AdminLoginChallenge {
  id           String    @id @default(cuid())
  adminId      String
  admin        Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  attemptCount Int       @default(0)
  usedAt       DateTime?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([adminId])
  @@index([expiresAt])
  @@index([usedAt])
}

model AdminSession {
  id         String    @id @default(cuid())
  adminId    String
  admin      Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([adminId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Notification {
  id         String    @id @default(cuid())
  type       String
  title      String
  message    String
  targetType String?
  targetId   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([readAt])
  @@index([type])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ── Security Dashboard Additions ──────────────────────────────────────────────

model IpProfile {
  id String @id @default(cuid())
  ip String @unique

  country String?
  city    String?
  region  String?

  // Example: AS38623 VIETTEL CAMBODIA PTE., LTD
  isp String?

  // Example: Smart | Metfone | Cellcard | Ezecom | Unknown
  provider String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider])
  @@index([country])
  @@index([updatedAt])
}

model RequestLog {
  id String @id @default(cuid())

  ip         String
  method     String?
  path       String
  statusCode Int?

  country  String?
  isp      String?
  provider String?

  device    String?
  os        String?
  browser   String?
  userAgent String?
  referer   String?

  blocked   Boolean @default(false)
  isBot     Boolean @default(false)
  riskScore Int     @default(0)

  createdAt DateTime @default(now())

  @@index([ip])
  @@index([path])
  @@index([provider])
  @@index([blocked])
  @@index([isBot])
  @@index([riskScore])
  @@index([createdAt])
}

model AdminLoginLog {
  id String @id @default(cuid())

  adminEmail String?
  ip         String

  country  String?
  isp      String?
  provider String?

  device    String?
  os        String?
  browser   String?
  userAgent String?

  success Boolean @default(true)
  message String?

  createdAt DateTime @default(now())

  @@index([adminEmail])
  @@index([ip])
  @@index([provider])
  @@index([success])
  @@index([createdAt])
}

// ── Existing Security Additions ───────────────────────────────────────────────

model ProcessedWebhookEvent {
  id            String   @id @default(cuid())
  transactionId String   @unique
  orderNumber   String?
  processedAt   DateTime @default(now())

  @@index([processedAt])
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String
  ip        String?
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@index([ip])
}

model UsedTotpToken {
  id        String   @id @default(cuid())
  adminId   String
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([adminId, token])
  @@index([adminId])
  @@index([expiresAt])
}
